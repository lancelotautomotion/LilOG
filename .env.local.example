# Shopify Storefront API — see README.md for how to generate these in Shopify admin
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-api-access-token
SHOPIFY_STOREFRONT_API_VERSION=2025-01

# NextAuth — generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=your-auth-secret-here

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-domain.com/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# App URL (required for NextAuth in production)
NEXTAUTH_URL=https://your-domain.com
